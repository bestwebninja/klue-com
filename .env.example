# Shared
NODE_ENV=development

# API
PORT=4000
DATABASE_URL=postgresql://kluje:kluje@localhost:5432/kluje
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-strong-secret
JWT_ISSUER=kluje-api
JWT_AUDIENCE=kluje-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID_STARTER=price_starter_placeholder
STRIPE_PRICE_ID_GROWTH=price_growth_placeholder
STRIPE_PRODUCT_ID_STARTER=prod_starter_placeholder
STRIPE_PRODUCT_ID_GROWTH=prod_growth_placeholder
STRIPE_CHECKOUT_SUCCESS_URL=https://dashboard.kluje.com/billing/success
STRIPE_CHECKOUT_CANCEL_URL=https://dashboard.kluje.com/billing/cancel

# Web
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Edge Function secrets (server-side only)
# Configure these in Supabase project secrets, not the browser.
CENSUS_API_KEY=replace_with_census_api_key

# n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=replace-with-32-char-secret
WEBHOOK_URL=http://localhost:5678/


# ZIP Explorer (public/browser optional config)
# Optional provider integrations below are intentionally stubbed in-browser unless proxied server-side.
VITE_PUBLIC_SITE_URL=https://kluje.com
VITE_AIRNOW_API_BASE_URL=
VITE_AIRNOW_API_KEY=
VITE_WALKSCORE_API_BASE_URL=
VITE_WALKSCORE_API_KEY=
VITE_GREATSCHOOLS_API_BASE_URL=
VITE_GREATSCHOOLS_API_KEY=
VITE_KLUJE_RISK_API_BASE_URL=
VITE_KLUJE_RISK_API_KEY=
# Note: Walk Score, GreatSchools, and Kluje Risk keys should not be exposed directly in production browsers; use proxy endpoints.
