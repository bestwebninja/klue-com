        "method": "POST",
        "url": "http://api:4000/api/v1/notifications/transactional",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"type\": \"advertiser.welcome\",\n  \"tenant_id\": $('Webhook - onboarding.requested').item.json.tenant_id,\n  \"correlation_id\": $('Webhook - onboarding.requested').item.json.correlation_id,\n  \"payload\": $json\n}"
      }
    },
    {
