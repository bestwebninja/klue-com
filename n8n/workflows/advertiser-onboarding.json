      "parameters": {
        "language": "JavaScript",
        "jsCode": "const requiredEnvelope = ['event_id', 'event_type', 'event_version', 'tenant_id', 'correlation_id', 'occurred_at', 'payload'];\nfor (const item of items) {\n  for (const field of requiredEnvelope) {\n    if (item.json[field] === undefined || item.json[field] === null || item.json[field] === '') {\n      throw new Error(`schema_validation_error: missing ${field}`);\n    }\n  }\n  if (item.json.event_type !== 'advertiser.onboarding.requested') {\n    throw new Error(`unsupported_event_type: ${item.json.event_type}`);\n  }\n}\nreturn items;"
      }
    },
    {
      "id": "3",
      "name": "Check idempotency key",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -480,
        260
      ],
      "parameters": {
        "method": "POST",
        "url": "http://api:4000/api/v1/ops/idempotency/check",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-correlation-id",
              "value": "={{ $json.correlation_id }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"key\": $json.event_id,\n  \"scope\": \"workflow.advertiser_onboarding\"\n}"
      }
    },
    {
