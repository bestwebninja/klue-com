          }
        ]
      ]
    },
    "Has more targets?": {
      "main": [
        [
          {
            "node": "Split targets",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Emit dispatch completion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Emit dispatch completion": {
      "main": [
        [
          {
