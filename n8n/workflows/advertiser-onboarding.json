          "parameters": [
            {
              "name": "x-correlation-id",
              "value": "={{ $('Webhook - onboarding.requested').item.json.correlation_id }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"event\": $('Webhook - onboarding.requested').item.json}"
      }
    },
    {
      "id": "7",
      "name": "Send welcome notification",
