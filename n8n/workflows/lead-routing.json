          }
        ]
      ]
    },
    "Split targets": {
      "main": [
        [
          {
            "node": "Deliver to target adapter",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Deliver to target adapter": {
      "main": [
        [
          {
            "node": "Record delivery outcome",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Record delivery outcome": {
      "main": [
        [
          {
            "node": "Has more targets?",
            "type": "main",
