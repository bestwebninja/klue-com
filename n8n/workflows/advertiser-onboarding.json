          "boolean": [
            {
              "value1": "={{ $json.alreadyProcessed || false }}",
              "value2": true
            }
          ]
        }
      }
    },
    {
      "id": "5",
      "name": "No-op duplicate",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.3,
      "position": [
        -20,
        140
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"status\":\"duplicate\",\"event_id\":$json.event_id,\"correlation_id\":$json.correlation_id}"
      }
    },
    {
      "id": "6",
